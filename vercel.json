{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "main.py"
    }
  },
  "rewrites": [
    { "source": "/auth(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/documents(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/api(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/health(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/index(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/adaptive(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/multimodal(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/debug(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/graph(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/ws(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/(.*)", "destination": { "type": "service", "service": "frontend" } }
  ]
}